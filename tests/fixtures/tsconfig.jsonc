{
  "compilerOptions": {
    // Target modern runtimes
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true, // enable all strict checks
    "outDir": "./dist",
    "rootDir": "./src",
    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
